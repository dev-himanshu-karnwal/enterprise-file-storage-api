# API
API_PORT=8000
APP_ENV=development
DEBUG=true

# PostgreSQL
POSTGRES_USER=efs
POSTGRES_PASSWORD=efs
POSTGRES_DB=efs
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://efs:efs@localhost:5432/efs

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# Auth / JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=60

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AWS S3 (fill these after AWS setup)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=
# Optional for LocalStack/MinIO:
# S3_ENDPOINT_URL=http://localhost:4566
S3_PRESIGN_EXPIRE_SECONDS=3600
MAX_UPLOAD_SIZE_BYTES=104857600

# Required for browser direct uploads (bucket CORS JSON):
# [
#   {
#     "AllowedHeaders": ["*"],
#     "AllowedMethods": ["GET", "PUT", "HEAD"],
#     "AllowedOrigins": ["http://localhost:5173", "http://127.0.0.1:5173"],
#     "ExposeHeaders": ["ETag", "x-amz-request-id"],
#     "MaxAgeSeconds": 3000
#   }
# ]

# Trash purge (soft-deleted files/folders). PRD default: 30 days.
# Local testing tip: TRASH_RETENTION_SECONDS=60 and TRASH_PURGE_INTERVAL_SECONDS=20
TRASH_RETENTION_SECONDS=2592000
TRASH_PURGE_INTERVAL_SECONDS=3600
